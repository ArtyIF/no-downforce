[node name="PaddingAfter" type="Control" parent="UI/CreditsDialog/Scroll/VBox"]
custom_minimum_size = Vector2(0, 530)
layout_mode = 2
mouse_filter = 2

[node name="LastNote" type="Label" parent="UI/CreditsDialog/Scroll/VBox"]
layout_mode = 2
text = "Scroll up or reopen credits to restart credits"
