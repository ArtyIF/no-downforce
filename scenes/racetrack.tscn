[node name="Warning" type="Label" parent="UI/DemoOverlay/OutdatedDemoWarning/VBox"]
layout_mode = 2
text = "The loaded demo was recorded in a different version and may be broken!"
horizontal_alignment = 1
vertical_alignment = 1

[node name="Version" type="Label" parent="UI/DemoOverlay/OutdatedDemoWarning/VBox"]
layout_mode = 2
theme_type_variation = &"MatrixLargeLabel"
text = "0.1"
horizontal_alignment = 1
vertical_alignment = 1

[node name="Demo" type="PanelContainer" parent="UI/DemoOverlay"]
layout_mode = 1
anchors_preset = -1
anchor_left = 0.5
anchor_right = 0.5
grow_horizontal = 2

[node name="VBox" type="VBoxContainer" parent="UI/DemoOverlay/Demo"]
layout_mode = 2

[node name="DemoPlayback" type="Label" parent="UI/DemoOverlay/Demo/VBox"]
layout_mode = 2
text = "Demo Playback
Press reset to stop
TODO: better controls"
horizontal_alignment = 1
vertical_alignment = 1

[node name="DemoFileDialog" type="FileDialog" parent="UI"]
title = "Open a File"
initial_position = 2
ok_button_text = "Open"
file_mode = 0
access = 1
filters = PackedStringArray("*.res;Resource Files")
use_native_dialog = true
script = ExtResource("24_mkv83")

[node name="ErrorDialog" type="AcceptDialog" parent="UI"]
title = "Error!"
initial_position = 2
size = Vector2i(165, 100)
popup_window = true
dialog_text = "Error text goes here"

[node name="CreditsDialog" type="AcceptDialog" parent="UI"]
title = "Credits"
initial_position = 2
size = Vector2i(800, 600)
ok_button_text = "Close"

[node name="Scroll" type="ScrollContainer" parent="UI/CreditsDialog"]
offset_left = 10.0
offset_top = 10.0
offset_right = 790.0
offset_bottom = 541.0
horizontal_scroll_mode = 0
vertical_scroll_mode = 3
script = ExtResource("27_ht4hr")

[node name="VBox" type="VBoxContainer" parent="UI/CreditsDialog/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="PaddingBefore" type="Control" parent="UI/CreditsDialog/Scroll/VBox"]
custom_minimum_size = Vector2(0, 530)
layout_mode = 2
mouse_filter = 2

[node name="CreditsLabel" type="RichTextLabel" parent="UI/CreditsDialog/Scroll/VBox"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
mouse_filter = 1
bbcode_enabled = true
text = "[color=#ff6000]Most of the things[/color]
	ArtyIF

[color=#ff6000]Sounds[/color]
	[color=#ff6000]screeching tyres / tires[/color] by [color=#ff6000]fractanimal[/color] -- [url]https://freesound.org/s/614627/[/url]
		[color=#ff6000]License:[/color] CC0 1.0 ([url]https://creativecommons.org/publicdomain/zero/1.0/[/url])
		[color=#ff6000]Changes made:[/color] Trimmed and looped, converted to OGG
	[color=#ff6000]Collision 1[/color] by [color=#ff6000]JustInvoke[/color] -- [url]https://freesound.org/s/446126/[/url]
		[color=#ff6000]License:[/color] CC BY 4.0 ([url]https://creativecommons.org/licenses/by/4.0/[/url])
		[color=#ff6000]Changes made:[/color] Converted to OGG
	[color=#ff6000]Collision 2[/color] by [color=#ff6000]JustInvoke[/color] -- [url]https://freesound.org/s/446125/[/url]
		[color=#ff6000]License:[/color] CC BY 4.0 ([url]https://creativecommons.org/licenses/by/4.0/[/url])
		[color=#ff6000]Changes made:[/color] Converted to OGG
	[color=#ff6000]Collision 3[/color] by [color=#ff6000]JustInvoke[/color] -- [url]https://freesound.org/s/446132/[/url]
		[color=#ff6000]License:[/color] CC BY 4.0 ([url]https://creativecommons.org/licenses/by/4.0/[/url])
		[color=#ff6000]Changes made:[/color] Converted to OGG
	[color=#ff6000]metal plate scratch[/color] by [color=#ff6000]Ridderick[/color] -- [url]https://freesound.org/s/707639/[/url]
		[color=#ff6000]License:[/color] CC0 1.0 ([url]https://creativecommons.org/publicdomain/zero/1.0/[/url])
		[color=#ff6000]Changes made:[/color] Trimmed and looped, converted to OGG
	[color=#ff6000]Car Land/Hit[/color] by [color=#ff6000]JustInvoke[/color] -- [url]https://freesound.org/s/446135/[/url]
		[color=#ff6000]License:[/color] CC BY 4.0 ([url]https://creativecommons.org/licenses/by/4.0/[/url])
		[color=#ff6000]Changes made:[/color] Converted to OGG
	[color=#ff6000]Hurricane Ophelia - Youghal, Co. Cork, Ireland - 16th October 2017 (2)[/color] by [color=#ff6000]midaza.com[/color] -- [url]https://freesound.org/s/404946/[/url]
		[color=#ff6000]License:[/color] CC BY 4.0 ([url]https://creativecommons.org/licenses/by/4.0/[/url])
		[color=#ff6000]Changes made:[/color] Trimmed and looped, converted to OGG

	Engine sounds created with [url]https://github.com/DasEtwas/enginesound[/url] from on example .esc files

[color=#ff6000]Textures[/color]
