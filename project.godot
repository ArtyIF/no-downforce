; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="No Downforce"
config/version="0.6.5"
run/main_scene="res://scenes/racetrack.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/bg_color=Color(0.05, 0.0345833, 0.025, 1)
boot_splash/image="uid://cb15rtci1iogw"
config/icon="uid://cqd2jbn0sxn6y"
boot_splash/minimum_display_time=1000

[autoload]

AACCGlobal="*res://addons/aacc/scripts/aacc_global.gd"
NoDownforceGlobal="*res://scripts/no_downforce_global.gd"
UISoundAutoload="*res://scripts/ui/ui_sound_autoload.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/aacc/plugin.cfg")

[gui]

theme/custom="uid://br8g18fol6tdx"

