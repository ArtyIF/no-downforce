[layer_names]

3d_render/layer_2="Car"

[physics]

common/physics_ticks_per_second=180
common/physics_jitter_fix=0.0

[rendering]

environment/screen_space_reflection/roughness_quality=2
anti_aliasing/quality/msaa_3d=1
